# Required in production
REDIS_URL=redis://redis:6379/0
PUBLIC_BASE_URL=https://mcp.voevoda-sailing.ru

# Defaults are intentionally short because survey links are conversational artifacts.
SURVEY_LINK_TTL_SECONDS=3600
SURVEY_COMPLETED_TTL_SECONDS=10800
REDIS_KEY_PREFIX=mcp-surveys
CREATE_SURVEY_RATE_LIMIT_PER_HOUR=60
MAX_CREATE_SURVEY_BYTES=131072
